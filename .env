# .env is better suited for public variables, ie, variables that should not commited
# For secret variables is better to use DevServerControl tool with set_env_variable: ["KEY", "SECRET"]

# https://www.builder.io/c/docs/using-your-api-key
VITE_PUBLIC_BUILDER_KEY=__BUILDER_PUBLIC_KEY__
PING_MESSAGE="ping pong"

# Google Apps Script Configuration
VITE_GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbyq_eYQbJUSJkv9clOOzYFiLVFYyAcj8j37IxNUDm0CHyCi8Dct6RoI9boyQM2Fh5oS/exec

# EmailJS Configuration (Legacy - can be removed if using Google Apps Script)
# Get these values from https://www.emailjs.com/
# See EMAILJS_SETUP.md for detailed setup instructions
VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
